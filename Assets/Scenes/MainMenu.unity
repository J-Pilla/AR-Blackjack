  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Blackjack Instructions:\n\n1. Each player is dealt 2 cards. The dealer
    also gets 2 cards (1 face up, 1 face down).\n\n2. Number cards = their value;
    Face cards (J, Q, K) = 10; Ace = 1 or 11.\n\n3. Players try to get as close to
    21 as possible without going over.\n\n4. On your turn, choose to:\n\tHit \u2013
    take another card.\n\tStand \u2013 keep your current hand.\n\n5. If your hand
    goes over 21, you bust and lose.\n\n6. After all players finish, the dealer reveals
    their hidden card and must hit until 17 or higher.\n\n7. The closest to 21 without
    busting wins!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
